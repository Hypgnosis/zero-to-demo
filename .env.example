# ═══════════════════════════════════════════════════════════════════
# Axiom-0 / Axiom-G — Environment Variables
#
# Phase 5: Dual-Mode Architecture (Zero-Trust Architect V2)
#
# Copy this file to .env.local and fill in your real values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════════

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ═══════════════════════════════════════════════════════════════════
# Phase 1: Zero-Trust Identity
# ═══════════════════════════════════════════════════════════════════

# Authentication — JWKS endpoint for JWT verification.
# Supports: Clerk, Auth0, Firebase, any OIDC-compliant provider.
#
# Clerk:    https://your-app.clerk.accounts.dev/.well-known/jwks.json
# Auth0:    https://your-tenant.auth0.com/.well-known/jwks.json
# Firebase: https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
AUTH_JWKS_URL=

# Optional but RECOMMENDED for production:
# AUTH_ISSUER=https://your-clerk-domain
# AUTH_AUDIENCE=your-app-id

# ── Development Only ──────────────────────────────────────────────
# Set to 'true' to bypass JWT verification in development.
# This WILL NOT WORK in production (NODE_ENV=production) — fail closed.
AXIOM_AUTH_BYPASS=true

# ═══════════════════════════════════════════════════════════════════
# Phase 1: Voice Proxy Secret
# ═══════════════════════════════════════════════════════════════════

# DEDICATED secret for voice proxy JWT signing.
# MUST be different from UPSTASH_REDIS_REST_TOKEN and QSTASH_CURRENT_SIGNING_KEY.
# Generate with: openssl rand -hex 32
VOICE_PROXY_SECRET=

# ═══════════════════════════════════════════════════════════════════
# Phase 5: PHYSICAL ISOLATION — Two Vector Indexes
#
# CRITICAL: AXIOM_0 and AXIOM_G MUST point to DIFFERENT physical
# Upstash Vector instances. If they are the same URL, the application
# will refuse to start (process.exit(1)).
#
# Axiom-0: Ephemeral demo data (auto-purged after 4h).
# Axiom-G: Enterprise governed data (persistent, BYOK-ready).
# ═══════════════════════════════════════════════════════════════════

# Axiom-0 Ephemeral Vector Index (demo/ephemeral sessions)
AXIOM_0_VECTOR_URL=
AXIOM_0_VECTOR_TOKEN=

# Axiom-G Governed Vector Index (enterprise/persistent sessions)
# Must be a DIFFERENT physical instance from AXIOM_0.
AXIOM_G_VECTOR_URL=
AXIOM_G_VECTOR_TOKEN=

# ═══════════════════════════════════════════════════════════════════
# Phase 4: KEY SOVEREIGNTY — Envelope Encryption
# ═══════════════════════════════════════════════════════════════════

# Root Key for BYOK (Bring Your Own Key) pattern.
# This key protects the Session DEKs (Data Encryption Keys).
# Format: 32-byte hex string (64 characters).
# Generate with: openssl rand -hex 32
AXIOM_G_ROOT_KEY=

# ═══════════════════════════════════════════════════════════════════
# Infrastructure
# ═══════════════════════════════════════════════════════════════════

# Upstash Redis (rate limiting, session state, job tracking)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# QStash (async job queue)
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# Voice Proxy URL (Cloud Run endpoint)
# VOICE_PROXY_URL=

# Cron Secret (for Vercel Cron authentication)
# CRON_SECRET=

# ═══════════════════════════════════════════════════════════════════
# REMOVED (Phase 2: Ghost Pipeline)
# ═══════════════════════════════════════════════════════════════════
# BLOB_READ_WRITE_TOKEN — REMOVED. Files stream directly to GenAI.
# UPSTASH_VECTOR_REST_URL — REPLACED by AXIOM_0 / AXIOM_G split.
# UPSTASH_VECTOR_REST_TOKEN — REPLACED by AXIOM_0 / AXIOM_G split.
